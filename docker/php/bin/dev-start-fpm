#!/bin/sh
set -e

if [ -d "/var/www" ]; then
    echo "Adjusting permissions for /var/www..."
    chown -R www-data:www-data /var/www
else
    echo "Directory /var/www does not exist!" >&2
    exit 1
fi

if ! command -v docker-php-entrypoint >/dev/null 2>&1; then
    echo "docker-php-entrypoint not found!" >&2
    exit 1
fi

DB_HOST="${DB_HOST:-db}"
DB_PORT="${DB_PORT:-3306}"
DB_USER="${DB_USER:-mysql}"
DB_PASS="${DB_PASS:-mysql}"

  echo "Running composer install..."
  composer install --prefer-dist --no-progress --no-suggest

  echo "Waiting for database at $DB_HOST:$DB_PORT..."
  until mysql -h"$DB_HOST" -P"$DB_PORT" -u"$DB_USER" -p"$DB_PASS" -e "SELECT 1;"; do
      sleep 2
  done
  echo "Database is ready!"

  echo "Running database migrations..."
  php bin/console doctrine:migrations:migrate -vv --no-interaction

  echo "Running database fixtures"
  php bin/console doctrine:fixtures:load -vv --no-interaction

echo "Starting PHP-FPM as $(whoami)..."
exec docker-php-entrypoint "php-fpm"