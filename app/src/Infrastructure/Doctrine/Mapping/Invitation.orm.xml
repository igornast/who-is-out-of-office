<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Infrastructure\Doctrine\Entity\Invitation" table="invitation">
        <id name="id" type="uuid" column="id">
            <generator strategy="CUSTOM"/>
            <custom-id-generator class="Ramsey\Uuid\Doctrine\UuidGenerator" />
        </id>

        <field name="token" length="255" unique="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>

        <one-to-one field="user" target-entity="App\Infrastructure\Doctrine\Entity\User">
            <join-column name="user_id" referenced-column-name="id" nullable="false" unique="true" on-delete="CASCADE"/>
        </one-to-one>
    </entity>
</doctrine-mapping>
