<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Infrastructure\Doctrine\Entity\PasswordResetToken" table="password_reset_token">
        <id name="id" type="uuid" column="id">
            <generator strategy="CUSTOM"/>
            <custom-id-generator class="Ramsey\Uuid\Doctrine\UuidGenerator" />
        </id>

        <field name="token" length="64" unique="true"/>
        <field name="expiresAt" type="datetime_immutable" column="expires_at"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>

        <many-to-one field="user" target-entity="App\Infrastructure\Doctrine\Entity\User">
            <join-column name="user_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
    </entity>
</doctrine-mapping>
