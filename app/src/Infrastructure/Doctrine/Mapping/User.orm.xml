<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Infrastructure\Doctrine\Entity\User" table="user">
        <id name="id" type="uuid" column="id">
            <generator strategy="CUSTOM"/>
            <custom-id-generator class="Ramsey\Uuid\Doctrine\UuidGenerator" />
        </id>

        <field name="firstName" column="first_name" length="255"/>
        <field name="lastName" column="last_name" length="255"/>
        <field name="email" column="email" length="200" unique="true"/>
        <field name="password" column="password" length="255" />
        <field name="roles" column="roles" type="json" />
        <field name="annualLeaveAllowance" column="annual_leave_allowance"  type="integer"/>
        <field name="currentLeaveBalance" column="current_leave_balance"  type="integer"/>
        <field name="isActive" column="is_active" type="boolean" />
        <field name="hasCelebrateWorkAnniversary" column="celebrate_work_anniversary" type="boolean" />
        <field name="profileImageUrl" column="profile_image_url" length="255" nullable="true" />
        <field name="birthDate" column="birth_date" type="date_immutable" nullable="true" />
        <field name="contractStartedAt" column="contract_started_at" type="date_immutable" nullable="true" />
        <field name="workingDays" type="json" column="working_days" />
        <field name="absenceBalanceResetDay" column="absence_balance_reset_day" type="date_immutable"/>

        <field name="createdAt" column="created_at" type="datetime_immutable"/>
        <field name="updatedAt" column="updated_at" type="datetime_immutable"/>

        <one-to-one field="slackIntegration" target-entity="App\Infrastructure\Doctrine\Entity\UserSlackIntegration" mapped-by="user">
            <cascade>
                <cascade-persist/>
                <cascade-remove/>
            </cascade>
        </one-to-one>

        <many-to-one field="holidayCalendar" target-entity="App\Infrastructure\Doctrine\Entity\HolidayCalendar">
            <join-column name="holiday_calendar_id" referenced-column-name="id" nullable="true" />
        </many-to-one>

        <lifecycle-callbacks>
            <lifecycle-callback type="preUpdate" method="updateTimestamp" />
        </lifecycle-callbacks>
    </entity>
</doctrine-mapping>