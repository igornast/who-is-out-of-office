<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Infrastructure\Doctrine\Entity\Holiday" table="holiday">
        <id name="id" type="uuid" column="id">
            <generator strategy="CUSTOM"/>
            <custom-id-generator class="Ramsey\Uuid\Doctrine\UuidGenerator" />
        </id>

        <field name="description" column="description" length="255"/>
        <field name="date" type="date_immutable" column="date" />
        <field name="isGlobal" column="is_global" type="boolean"/>
        <field name="counties" column="counties" type="json" nullable="true"/>

        <many-to-one field="holidayCalendar" target-entity="App\Infrastructure\Doctrine\Entity\HolidayCalendar" inversed-by="holidays">
            <join-column name="holiday_calendar_id" nullable="false" />
        </many-to-one>

        <field name="createdAt" column="created_at" type="datetime_immutable"/>
        <field name="updatedAt" column="updated_at" type="datetime_immutable"/>

        <lifecycle-callbacks>
            <lifecycle-callback type="preUpdate" method="updateTimestamp" />
        </lifecycle-callbacks>
    </entity>
</doctrine-mapping>