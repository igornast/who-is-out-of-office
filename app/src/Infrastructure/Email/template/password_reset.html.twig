{% extends '@AppEmail/base.html.twig' %}

{% block subject %}{{ 'email.password_reset.subject'|trans }}{% endblock %}

{% block preheader %}{{ 'email.password_reset.preheader'|trans }}{% endblock %}

{% block content %}

    {# Greeting #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 20px; font-weight: bold; color: #1A2E2E; margin-bottom: 8px;">
                {{ 'email.password_reset.title'|trans }}
            </td>
        </tr>
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; color: #6B8080; line-height: 1.6; padding-bottom: 24px;">
                {{ 'email.password_reset.body'|trans }}
            </td>
        </tr>
    </table>

    {# CTA Button #}
    <table cellpadding="0" cellspacing="0" border="0" style="margin: 24px auto;">
        <tr>
            <td align="center" style="background-color: #E8876F; border-radius: 8px;">
                <a href="{{ reset_url }}" target="_blank" style="display: inline-block; padding: 14px 32px; font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; font-weight: 600; color: #FFFFFF; text-decoration: none;">
                    {{ 'email.password_reset.button'|trans }}
                </a>
            </td>
        </tr>
    </table>

    {# Link fallback #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #8A9E9E; line-height: 1.6; padding-bottom: 24px;">
                {{ 'email.password_reset.link_fallback'|trans }}<br>
                <a href="{{ reset_url }}" style="color: #3D9B8F; word-break: break-all;">{{ reset_url }}</a>
            </td>
        </tr>
    </table>

    {# Expiry note #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #8A9E9E; line-height: 1.6; padding-bottom: 24px; border-bottom: 1px solid #E8EFEC;">
                <strong>{{ 'email.password_reset.expiry_note'|trans }}</strong>
            </td>
        </tr>
    </table>

    {# Security note #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="padding: 24px 0;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #8A9E9E; line-height: 1.6;">
                            {{ 'email.password_reset.footer'|trans }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

{% endblock %}
