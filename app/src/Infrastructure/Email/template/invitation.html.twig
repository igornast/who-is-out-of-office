{% extends '@AppEmail/base.html.twig' %}

{% block subject %}{{ 'email.invitation.subject'|trans }}{% endblock %}

{% block preheader %}{{ 'email.invitation.preheader'|trans({'%inviter_name%': inviter_name|default('email.invitation.default_inviter'|trans)}) }}{% endblock %}

{% block content %}

    {# Greeting #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 20px; font-weight: bold; color: #1A2E2E; margin-bottom: 8px;">
                {{ 'email.invitation.heading'|trans }}
            </td>
        </tr>
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; color: #6B8080; line-height: 1.6; padding-bottom: 20px;">
                {{ 'email.invitation.intro'|trans({
                    '%inviter_name%': inviter_name|default('email.invitation.default_inviter'|trans),
                    '%company%': company_name is defined and company_name ? company_name : 'email.invitation.organization_default'|trans
                }) }}
            </td>
        </tr>
    </table>

    {# Invitation details card #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 24px 0;">
        <tr>
            <td style="background-color: #F5F8F7; border-left: 4px solid #3D9B8F; padding: 20px 24px; border-radius: 4px;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #8A9E9E; text-transform: uppercase; letter-spacing: 0.5px; padding-bottom: 4px;">
                            {{ 'email.invitation.role_label'|trans }}
                        </td>
                    </tr>
                    <tr>
                        <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; color: #1A2E2E; font-weight: bold; padding-bottom: 20px;">
                            {{ role|default('email.invitation.role_default'|trans) }}
                        </td>
                    </tr>
                    <tr>
                        <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #8A9E9E; text-transform: uppercase; letter-spacing: 0.5px; padding-bottom: 4px;">
                            {{ 'email.invitation.organization_label'|trans }}
                        </td>
                    </tr>
                    <tr>
                        <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; color: #1A2E2E; font-weight: bold;">
                            {% if company_name is defined and company_name %}{{ company_name }}{% else %}{{ 'email.invitation.organization_default'|trans }}{% endif %}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    {# Description paragraph #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #6B8080; line-height: 1.6; padding-bottom: 24px;">
                {{ 'email.invitation.description'|trans }}
            </td>
        </tr>
    </table>

    {# CTA Button #}
    <table cellpadding="0" cellspacing="0" border="0" style="margin: 24px auto;">
        <tr>
            <td align="center" style="background-color: #E8876F; border-radius: 8px;">
                <a href="{{ invitation_url }}" target="_blank" style="display: inline-block; padding: 14px 32px; font-family: 'Sora', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 15px; font-weight: 600; color: #FFFFFF; text-decoration: none;">
                    {{ 'email.invitation.button'|trans }}
                </a>
            </td>
        </tr>
    </table>

{% endblock %}
