{% extends 'base.html.twig' %}

{% block title %}{{ 'password_reset.request.page_title'|trans }}{% endblock %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/invitation.css') }}">
{% endblock %}

{% block body %}
    <div class="invitation-page">
        <div class="invitation-card">
            <h1>{{ 'password_reset.request.heading'|trans }}</h1>
            <p class="invitation-subtitle">{{ 'password_reset.request.description'|trans }}</p>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success mb-3" style="font-size: 13px; border-radius: var(--radius-md);">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form) }}
                {{ form_row(form.email) }}

                <button type="submit" class="btn btn-primary w-100 mt-2">
                    {{ 'password_reset.request.submit'|trans }}
                </button>
            {{ form_end(form) }}

            <div class="text-center mt-3">
                <a href="{{ path('app_login') }}" style="font-size: 13px; color: var(--text-tertiary); text-decoration: none;">
                    {{ 'password_reset.request.back_to_login'|trans }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}

{% block body_javascript %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
{% endblock %}
