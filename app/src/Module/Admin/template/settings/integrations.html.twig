{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}{{ 'settings.integrations.title'|trans(domain='admin') }}{% endblock %}

{% block content_header %}
    <div class="content-header-title">
        <h1 class="title" style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text-primary);">
            {{ 'settings.integrations.title'|trans(domain='admin') }}
        </h1>
    </div>
{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'settings.integrations.slack.title'|trans(domain='admin') }}</h3>
                    <p class="settings-card-desc">{{ 'settings.integrations.slack.desc'|trans(domain='admin') }}</p>
                </div>
                <div class="settings-card-body">
                    <div class="settings-status-list">
                        <div class="settings-status-row">
                            <div class="settings-status-label">{{ 'settings.status.label'|trans(domain='admin') }}</div>
                            <div class="settings-status-value">
                                {% if slack_connected %}
                                    <span class="settings-badge settings-badge-success">{{ 'settings.status.active'|trans(domain='admin') }}</span>
                                {% else %}
                                    <span class="settings-badge settings-badge-muted">{{ 'settings.status.inactive'|trans(domain='admin') }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-card" style="margin-top: 20px;">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'settings.integrations.calendar.title'|trans(domain='admin') }}</h3>
                    <p class="settings-card-desc">{{ 'settings.integrations.calendar.desc'|trans(domain='admin') }}</p>
                </div>
                <div class="settings-card-body">
                    <div class="settings-status-list">
                        <div class="settings-status-row">
                            <div class="settings-status-label">{{ 'settings.status.label'|trans(domain='admin') }}</div>
                            <div class="settings-status-value">
                                {% if ical_enabled %}
                                    <span class="settings-badge settings-badge-success">{{ 'settings.status.active'|trans(domain='admin') }}</span>
                                {% else %}
                                    <span class="settings-badge settings-badge-muted">{{ 'settings.status.inactive'|trans(domain='admin') }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-card" style="margin-top: 20px;">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'settings.integrations.date_nager.title'|trans(domain='admin') }}</h3>
                    <p class="settings-card-desc">{{ 'settings.integrations.date_nager.desc'|trans(domain='admin') }}</p>
                </div>
                <div class="settings-card-body">
                    <div class="settings-status-list">
                        <div class="settings-status-row">
                            <div class="settings-status-label">{{ 'settings.status.label'|trans(domain='admin') }}</div>
                            <div class="settings-status-value">
                                {% if date_nager_enabled %}
                                    <span class="settings-badge settings-badge-success">{{ 'settings.status.active'|trans(domain='admin') }}</span>
                                {% else %}
                                    <span class="settings-badge settings-badge-muted">{{ 'settings.status.inactive'|trans(domain='admin') }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
