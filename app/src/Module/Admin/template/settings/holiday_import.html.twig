{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}{{ 'crud.holiday_import.title'|trans(domain='admin') }}{% endblock %}

{% block content_header %}
    <div class="content-header-title">
        <h1 class="title" style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text-primary);">
            {{ 'crud.holiday_import.title'|trans(domain='admin') }}
        </h1>
    </div>
{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            {{ form_start(form) }}

            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'crud.holiday_import.panel.title'|trans(domain='admin') }}</h3>
                    <p class="settings-card-desc">{{ 'crud.holiday_import.panel.desc'|trans(domain='admin') }}</p>
                </div>
                <div class="settings-card-body">
                    <div class="field-choice form-group mb-3">
                        <div class="form-widget">
                            {{ form_row(form.country, {'attr': {'class': 'form-control'}}) }}
                        </div>
                    </div>

                    <div class="field-integer form-group mb-0">
                        <div class="form-widget">
                            {{ form_row(form.year, {'attr': {'class': 'form-control'}}) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-card-footer">
                {{ form_errors(form) }}
                <button class="btn btn-primary">{{ 'crud.holiday_import.action.import'|trans(domain='admin') }}</button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
