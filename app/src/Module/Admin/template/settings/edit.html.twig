{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}{{ 'crud.app_settings.edit.title'|trans(domain='admin') }}{% endblock %}

{% block content_header %}
    <div class="content-header-title">
        <h1 class="title" style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text-primary);">
            {{ 'crud.app_settings.edit.title'|trans(domain='admin') }}
        </h1>
    </div>
{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div style="margin-bottom: 16px; padding: 12px 16px; background-color: var(--primary-subtle); border-left: 3px solid var(--primary); border-radius: var(--radius-md); font-size: 13px; color: var(--text-secondary);">
                <i data-lucide="info" style="width: 14px; height: 14px; display: inline-block; vertical-align: -2px; margin-right: 4px; color: var(--primary);"></i>
                {{ 'crud.app_settings.source_filename'|trans(domain='admin') ~ ": " ~ app_settings_filename }}
            </div>

            {{ form_start(form) }}

            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'crud.app_settings.panel.leave_request'|trans(domain='admin') }}</h3>
                    <p class="settings-card-desc">{{ 'crud.app_settings.panel.leave_request_desc'|trans(domain='admin') }}</p>
                </div>
                <div class="settings-card-body">
                    <div class="field-checkbox form-group mb-3">
                        <div class="checkbox-large">
                            {{ form_widget(form.autoApprove) }}
                            {{ form_label(form.autoApprove) }}
                        </div>
                        {{ form_errors(form.autoApprove) }}
                    </div>

                    <div class="field-integer form-group mb-0">
                        <div class="form-widget">
                            {{ form_row(form.autoApproveDelay, {'attr': {'class': 'form-control'}}) }}
                        </div>
                    </div>
                </div>
                <div class="settings-card-footer">
                    {{ form_errors(form) }}
                    <button class="btn btn-primary">{{ 'crud.app_settings.action.save'|trans(domain='admin') }}</button>
                </div>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
