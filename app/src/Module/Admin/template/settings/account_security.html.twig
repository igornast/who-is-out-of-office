{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}{{ 'settings.account_security.title'|trans(domain='admin') }}{% endblock %}

{% block content_header %}
    <div class="content-header-title">
        <h1 class="title" style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text-primary);">
            {{ 'settings.account_security.title'|trans(domain='admin') }}
        </h1>
    </div>
{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type }}" style="margin-bottom: 16px; border-radius: var(--radius-md); font-size: 13px;">
                        {{ message|trans(domain='admin') }}
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'settings.account_security.account_info.title'|trans(domain='admin') }}</h3>
                </div>
                <div class="settings-card-body">
                    <div class="settings-status-list">
                        <div class="settings-status-row">
                            <div class="settings-status-label">{{ 'settings.account_security.account_info.email'|trans(domain='admin') }}</div>
                            <div class="settings-status-value" style="font-weight: 500;">{{ user.email }}</div>
                        </div>
                        <div class="settings-status-row">
                            <div class="settings-status-label">{{ 'settings.account_security.account_info.role'|trans(domain='admin') }}</div>
                            <div class="settings-status-value">
                                {% if is_granted('ROLE_ADMIN') %}
                                    <span class="settings-badge settings-badge-success">{{ 'role.admin'|trans(domain='admin') }}</span>
                                {% elseif is_granted('ROLE_MANAGER') %}
                                    <span class="settings-badge settings-badge-success">{{ 'role.manager'|trans(domain='admin') }}</span>
                                {% else %}
                                    <span class="settings-badge settings-badge-muted">{{ 'role.user'|trans(domain='admin') }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="settings-status-row">
                            <div class="settings-status-label">{{ 'settings.account_security.account_info.member_since'|trans(domain='admin') }}</div>
                            <div class="settings-status-value">{{ user.createdAt|date('M d, Y') }}</div>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_start(form) }}
            <div class="settings-card" style="margin-top: 20px;">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'settings.account_security.change_password.title'|trans(domain='admin') }}</h3>
                    <p class="settings-card-desc">{{ 'settings.account_security.change_password.desc'|trans(domain='admin') }}</p>
                </div>
                <div class="settings-card-body">
                    <div class="field-text form-group mb-3">
                        <div class="form-widget">
                            {{ form_row(form.currentPassword, {'attr': {'class': 'form-control', 'autocomplete': 'current-password'}}) }}
                        </div>
                    </div>
                    <div class="field-text form-group mb-3">
                        <div class="form-widget">
                            {{ form_row(form.newPassword.first, {'attr': {'class': 'form-control', 'autocomplete': 'new-password'}}) }}
                        </div>
                    </div>
                    <div class="field-text form-group mb-0">
                        <div class="form-widget">
                            {{ form_row(form.newPassword.second, {'attr': {'class': 'form-control', 'autocomplete': 'new-password'}}) }}
                        </div>
                    </div>
                </div>
                <div class="settings-card-footer">
                    {{ form_errors(form) }}
                    <button class="btn btn-primary">{{ 'settings.account_security.action.update_password'|trans(domain='admin') }}</button>
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
