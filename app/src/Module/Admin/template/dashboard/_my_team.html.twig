{% import "@AppAdmin/dashboard/component/_user_avatar.html.twig" as avatar %}

<div class="card">
    <div class="card-header">
        <span class="card-title">{{ 'dashboard.title.my_team'|trans(domain: 'admin') }}</span>
        <span class="text-meta">{{ my_team|length }} {{ 'dashboard.my_team.members'|trans(domain: 'admin') }}</span>
    </div>
    <div class="card-body card-body-padded">
        {% if my_team is not empty %}
            <div class="d-flex flex-wrap gap-2">
                {% for userDto in my_team %}
                    {{ avatar.userDtoAvatar(userDto) }}
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state-text">
                {{ 'dashboard.my_team.empty'|trans(domain: 'admin') }}
            </div>
        {% endif %}
    </div>
</div>
