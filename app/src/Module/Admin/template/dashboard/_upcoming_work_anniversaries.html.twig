{% import "@AppAdmin/dashboard/component/_user_avatar.html.twig" as avatar %}

<div class="panel panel-primary">
    <div class="panel-heading border-bottom mb-4 d-flex align-items-center pb-3">
        <div class="me-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor"
                 class="bi bi-trophy-fill"
                 viewBox="0 0 16 16">
                <path d="M2.5.5A.5.5 0 0 1 3 0h10a.5.5 0 0 1 .5.5q0 .807-.034 1.536a3 3 0 1 1-1.133 5.89c-.79 1.865-1.878 2.777-2.833 3.011v2.173l1.425.356c.194.048.377.135.537.255L13.3 15.1a.5.5 0 0 1-.3.9H3a.5.5 0 0 1-.3-.9l1.838-1.379c.16-.12.343-.207.537-.255L6.5 13.11v-2.173c-.955-.234-2.043-1.146-2.833-3.012a3 3 0 1 1-1.132-5.89A33 33 0 0 1 2.5.5m.099 2.54a2 2 0 0 0 .72 3.935c-.333-1.05-.588-2.346-.72-3.935m10.083 3.935a2 2 0 0 0 .72-3.935c-.133 1.59-.388 2.885-.72 3.935"/>
            </svg>
        </div>
        <h6 class="panel-title text-body-emphasis mb-0">{{ 'dashboard.work_anniversaries.title'|trans(domain: 'admin') }}</h6>
    </div>
    <div class="panel-body card">
        <div class="card-body d-flex h-25">
            {% for userDto in users_with_work_anniversaries %}
                <div>
                    {{ avatar.userDtoAvatar(userDto) }}
                    <div class="w-100 pe-3 text-center text-secondary">
                        {{ userDto.contractStartedAt|date("m.d") }}
                        {% if userDto.contractStartedAt %}
                            {% set years = "now"|date("Y") - userDto.contractStartedAt|date("Y") %}
                            {% if years > 0 %}
                                <small class="d-block text-muted">{{ years }}y</small>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            {% endfor %}

            {% if users_with_work_anniversaries is empty %}
                <div class="alert alert-secondary w-100 text-center" role="alert">
                    <span class="text-secondary text-lowercase">{{ 'dashboard.work_anniversaries.no_upcoming'|trans(domain: 'admin') }}</span>
                </div>
            {% endif %}
        </div>
    </div>
</div>
