<div class="card quick-links-card">
    <div class="card-header">
        <span class="card-title">{{ 'dashboard.quick_links.title'|trans(domain: 'admin') }}</span>
    </div>
    <div class="card-body">
        <div class="quick-links">
            <a class="quick-link"
               href="{{ url('app_dashboard_requests_new') }}">
                <i data-lucide="plus-circle"></i>
                {{ 'dashboard.quick_links.new_request'|trans(domain: 'admin') }}
                <i data-lucide="chevron-right" class="quick-link-arrow"></i>
            </a>
            <a class="quick-link" href="{{ path('app_calendar_view') }}">
                <i data-lucide="calendar-days"></i>
                {{ 'dashboard.quick_links.team_calendar'|trans(domain: 'admin') }}
                <i data-lucide="chevron-right" class="quick-link-arrow"></i>
            </a>
            <a class="quick-link"
               href="{{ ea_url().setController('App\\Module\\Admin\\Controller\\LeaveRequest\\LeaveRequestCrudController').setAction('index') }}">
                <i data-lucide="file-text"></i>
                {{ 'dashboard.quick_links.leave_requests'|trans(domain: 'admin') }}
                <i data-lucide="chevron-right" class="quick-link-arrow"></i>
            </a>
            {% if is_admin or is_manager %}
                <a class="quick-link"
                   href="{{ ea_url().setController('App\\Module\\Admin\\Controller\\LeaveRequest\\TeamLeaveRequestCrudController').setAction('index') }}">
                    <i data-lucide="users"></i>
                    {{ 'dashboard.quick_links.team_leave_requests'|trans(domain: 'admin') }}
                    <i data-lucide="chevron-right" class="quick-link-arrow"></i>
                </a>
            {% endif %}
            {% if is_admin %}
                <a class="quick-link" href="{{ path('app_settings') }}">
                    <i data-lucide="settings"></i>
                    {{ 'dashboard.quick_links.app_settings'|trans(domain: 'admin') }}
                    <i data-lucide="chevron-right" class="quick-link-arrow"></i>
                </a>
            {% endif %}
            <a class="quick-link" href="{{ path('app_user_profile') }}">
                <i data-lucide="user-circle"></i>
                {{ 'dashboard.quick_links.my_profile'|trans(domain: 'admin') }}
                <i data-lucide="chevron-right" class="quick-link-arrow"></i>
            </a>
        </div>
    </div>
</div>
