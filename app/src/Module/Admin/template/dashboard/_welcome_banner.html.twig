<div class="welcome-banner">
    <div class="welcome-text">
        <h2 data-controller="greeting"
            data-greeting-name-value="{{ user.firstName }}"
            data-greeting-morning-value="{{ 'dashboard.welcome.greeting_morning'|trans(domain: 'admin') }}"
            data-greeting-afternoon-value="{{ 'dashboard.welcome.greeting_afternoon'|trans(domain: 'admin') }}"
            data-greeting-evening-value="{{ 'dashboard.welcome.greeting_evening'|trans(domain: 'admin') }}"
        >{{ 'dashboard.welcome.greeting'|trans({'%name%': user.firstName}, domain: 'admin') }}</h2>
        <p>{{ 'dashboard.welcome.balance'|trans({'%days%': user.currentLeaveBalance}, domain: 'admin') }}</p>
        <div class="welcome-actions">
            <a class="btn btn-cta"
               href="{{ url('app_dashboard_requests_new') }}">
                <i data-lucide="plus"></i>
                {{ 'dashboard.welcome.request_leave'|trans(domain: 'admin') }}
            </a>
            <a class="btn btn-outline-white" href="{{ path('app_calendar_view') }}">
                <i data-lucide="calendar-days"></i>
                {{ 'dashboard.welcome.view_calendar'|trans(domain: 'admin') }}
            </a>
        </div>
    </div>
    <div class="welcome-illustration">
        <img src="{{ asset('image/icons/icon_pride.png') }}" alt="Who's OOO" width="110" height="110" style="object-fit: contain; opacity: 0.85;">
    </div>
</div>
