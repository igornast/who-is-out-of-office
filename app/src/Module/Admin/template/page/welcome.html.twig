<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ 'welcome.page_title'|trans }}</title>
    <link rel="shortcut icon" href="{{ asset('image/icons/icon_pride.png') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/_tokens-light.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_tokens-dark.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_typography.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_palette-sage.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_palette-sunset.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_palette-lavender.css') }}">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--app-bg);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: background-color 0.25s ease;
        }

        .welcome-page {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ── Hero ── */
        .hero {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 24px 40px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -10%;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(61, 155, 143, 0.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(232, 135, 111, 0.04) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-content {
            max-width: 560px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        /* ── Logo mark ── */
        .logo-mark {
            display: inline-flex;
            margin-bottom: 28px;
        }

        .logo-mark img {
            width: 96px;
            height: 96px;
            object-fit: contain;
        }

        /* ── Typography ── */
        .app-name {
            font-family: var(--font-display);
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.02em;
            line-height: 1.15;
            margin-bottom: 8px;
        }

        .app-name span {
            color: var(--primary);
        }

        .tagline {
            font-size: 1.125rem;
            font-weight: 400;
            color: var(--text-tertiary);
            line-height: 1.6;
            margin-bottom: 36px;
        }

        /* ── CTA buttons ── */
        .cta-group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
            margin-bottom: 48px;
        }

        .btn-welcome {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: var(--font-body);
            font-size: 0.9375rem;
            font-weight: 500;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 150ms ease;
            border-radius: var(--radius-md);
        }

        .btn-welcome-primary {
            width: 280px;
            height: 48px;
            background: var(--primary);
            color: var(--text-on-primary);
            box-shadow: 0 2px 8px rgba(61, 155, 143, 0.3);
        }

        .btn-welcome-primary:hover {
            background: var(--primary-hover);
            box-shadow: 0 4px 12px rgba(61, 155, 143, 0.35);
            transform: translateY(-1px);
            color: var(--text-on-primary);
        }

        .btn-welcome-primary:active {
            background: var(--primary-active);
            transform: translateY(0);
        }

        .btn-welcome-primary svg {
            width: 18px;
            height: 18px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .btn-welcome-ghost {
            height: 40px;
            padding: 0 20px;
            background: transparent;
            color: var(--text-tertiary);
            font-size: 0.8125rem;
        }

        .btn-welcome-ghost:hover {
            color: var(--text-primary);
            background: var(--app-bg-alt);
        }

        .btn-welcome-ghost svg {
            width: 16px;
            height: 16px;
            fill: currentColor;
        }

        /* ── Feature pills ── */
        .features {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
        }

        .feature-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            background: var(--app-surface);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-full);
            font-size: 0.8125rem;
            font-weight: 400;
            color: var(--text-secondary);
            box-shadow: var(--shadow-sm);
        }

        .feature-pill svg {
            width: 14px;
            height: 14px;
            stroke: var(--primary);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* ── Supported by ── */
        .supported-by {
            margin-top: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .supported-by-label {
            font-size: 0.6875rem;
            font-weight: 500;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .supported-by-link {
            display: inline-flex;
            align-items: center;
            opacity: 0.55;
            transition: opacity 150ms ease;
        }

        .supported-by-link:hover {
            opacity: 0.85;
        }

        .supported-by-link svg {
            width: 120px;
            height: auto;
            fill: currentColor;
            color: var(--text-primary);
        }

        .supported-by-subtitle {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ── Footer ── */
        .welcome-footer {
            padding: 24px;
            text-align: center;
            border-top: 1px solid var(--border-light);
        }

        .footer-inner {
            max-width: 560px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

        .footer-links {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .footer-links a {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.8125rem;
            font-weight: 400;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 150ms ease;
        }

        .footer-links a:hover {
            color: var(--text-link);
        }

        .footer-links a svg {
            width: 14px;
            height: 14px;
            fill: currentColor;
        }

        .footer-divider {
            width: 1px;
            height: 14px;
            background: var(--border);
        }

        .footer-version {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ── Responsive ── */
        @media (max-width: 480px) {
            .hero {
                padding: 48px 20px 32px;
            }

            .logo-mark {
                width: 60px;
                height: 60px;
                margin-bottom: 24px;
            }

            .logo-mark img {
                width: 76px;
                height: 76px;
            }

            .app-name {
                font-size: 2rem;
            }

            .tagline {
                font-size: 1rem;
                margin-bottom: 28px;
            }

            .btn-welcome-primary {
                width: 100%;
                max-width: 300px;
            }

            .features {
                gap: 8px;
            }

            .feature-pill {
                font-size: 0.75rem;
                padding: 5px 12px;
            }

            .footer-links {
                flex-wrap: wrap;
                justify-content: center;
                gap: 16px;
            }
        }
    </style>
    <script>
        (function() {
            var saved = localStorage.getItem('whosooo-theme');
            var isDark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
            if (isDark) {
                document.documentElement.classList.add('dark', 'ea-dark-scheme');
                document.documentElement.dataset.bsTheme = 'dark';
                document.documentElement.style.colorScheme = 'dark';
            } else {
                document.documentElement.style.colorScheme = 'light';
            }
            var palette = localStorage.getItem('whosooo-palette') || 'teal';
            if (['teal','sage','sunset','lavender'].indexOf(palette) === -1) palette = 'teal';
            if (palette !== 'teal') document.documentElement.dataset.palette = palette;
        })();
    </script>
</head>
<body>

<div class="welcome-page">

    <section class="hero">
        <div class="hero-content">

            <div class="logo-mark">
                <img src="{{ asset('image/icons/icon_pride.png') }}" alt="Who's OOO">
            </div>

            <h1 class="app-name">Who's <span>OOO</span></h1>

            <p class="tagline">
                {{ 'welcome.tagline'|trans }}
            </p>

            <div class="cta-group">
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('app_dashboard') }}" class="btn-welcome btn-welcome-primary">
                        <svg viewBox="0 0 24 24">
                            <rect x="3" y="3" width="7" height="7"/>
                            <rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/>
                            <rect x="14" y="14" width="7" height="7"/>
