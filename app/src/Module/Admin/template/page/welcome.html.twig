<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ 'welcome.page_title'|trans }}</title>
    <link rel="shortcut icon" href="{{ asset('image/icons/icon_pride.png') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/_tokens-light.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_tokens-dark.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_typography.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_palette-sage.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_palette-sunset.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/_palette-lavender.css') }}">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--app-bg);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: background-color 0.25s ease;
        }

        .welcome-page {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ── Hero ── */
        .hero {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 24px 40px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -10%;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(61, 155, 143, 0.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(232, 135, 111, 0.04) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-content {
            max-width: 560px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        /* ── Logo mark ── */
        .logo-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, var(--primary), var(--primary-active));
            border-radius: var(--radius-xl);
            margin-bottom: 28px;
            box-shadow: 0 4px 20px rgba(61, 155, 143, 0.25);
        }

        .logo-mark svg {
            width: 38px;
            height: 38px;
            fill: none;
            stroke: white;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* ── Typography ── */
        .app-name {
            font-family: var(--font-display);
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.02em;
            line-height: 1.15;
            margin-bottom: 8px;
        }

        .app-name span {
            color: var(--primary);
        }

        .tagline {
            font-size: 1.125rem;
            font-weight: 400;
            color: var(--text-tertiary);
            line-height: 1.6;
            margin-bottom: 36px;
        }

        /* ── CTA buttons ── */
        .cta-group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
            margin-bottom: 48px;
        }

        .btn-welcome {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: var(--font-body);
            font-size: 0.9375rem;
            font-weight: 500;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 150ms ease;
            border-radius: var(--radius-md);
        }

        .btn-welcome-primary {
            width: 280px;
            height: 48px;
            background: var(--primary);
            color: var(--text-on-primary);
            box-shadow: 0 2px 8px rgba(61, 155, 143, 0.3);
        }

        .btn-welcome-primary:hover {
            background: var(--primary-hover);
            box-shadow: 0 4px 12px rgba(61, 155, 143, 0.35);
            transform: translateY(-1px);
            color: var(--text-on-primary);
        }

        .btn-welcome-primary:active {
            background: var(--primary-active);
            transform: translateY(0);
        }

        .btn-welcome-primary svg {
            width: 18px;
            height: 18px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .btn-welcome-ghost {
            height: 40px;
            padding: 0 20px;
            background: transparent;
            color: var(--text-tertiary);
            font-size: 0.8125rem;
        }

        .btn-welcome-ghost:hover {
            color: var(--text-primary);
            background: var(--app-bg-alt);
        }

        .btn-welcome-ghost svg {
            width: 16px;
            height: 16px;
            fill: currentColor;
        }

        /* ── Feature pills ── */
        .features {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
        }

        .feature-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            background: var(--app-surface);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-full);
            font-size: 0.8125rem;
            font-weight: 400;
            color: var(--text-secondary);
            box-shadow: var(--shadow-sm);
        }

        .feature-pill svg {
            width: 14px;
            height: 14px;
            stroke: var(--primary);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        /* ── Footer ── */
        .welcome-footer {
            padding: 24px;
            text-align: center;
            border-top: 1px solid var(--border-light);
        }

        .footer-inner {
            max-width: 560px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

        .footer-links {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .footer-links a {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.8125rem;
            font-weight: 400;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 150ms ease;
        }

        .footer-links a:hover {
            color: var(--text-link);
        }

        .footer-links a svg {
            width: 14px;
            height: 14px;
            fill: currentColor;
        }

        .footer-divider {
            width: 1px;
            height: 14px;
            background: var(--border);
        }

        .footer-version {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ── Responsive ── */
        @media (max-width: 480px) {
            .hero {
                padding: 48px 20px 32px;
            }

            .logo-mark {
                width: 60px;
                height: 60px;
                margin-bottom: 24px;
            }

            .logo-mark svg {
                width: 32px;
                height: 32px;
            }

            .app-name {
                font-size: 2rem;
            }

            .tagline {
                font-size: 1rem;
                margin-bottom: 28px;
            }

            .btn-welcome-primary {
                width: 100%;
                max-width: 300px;
            }

            .features {
                gap: 8px;
            }

            .feature-pill {
                font-size: 0.75rem;
                padding: 5px 12px;
            }

            .footer-links {
                flex-wrap: wrap;
                justify-content: center;
                gap: 16px;
            }
        }
    </style>
    <script>
        (function() {
            var saved = localStorage.getItem('whosooo-theme');
            var isDark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
            if (isDark) {
                document.documentElement.classList.add('dark', 'ea-dark-scheme');
                document.documentElement.dataset.bsTheme = 'dark';
                document.documentElement.style.colorScheme = 'dark';
            } else {
                document.documentElement.style.colorScheme = 'light';
            }
            var palette = localStorage.getItem('whosooo-palette') || 'teal';
            if (['teal','sage','sunset','lavender'].indexOf(palette) === -1) palette = 'teal';
            if (palette !== 'teal') document.documentElement.dataset.palette = palette;
        })();
    </script>
</head>
<body>

<div class="welcome-page">

    <section class="hero">
        <div class="hero-content">

            <div class="logo-mark">
                <svg viewBox="0 0 24 24">
                    <path d="M12 21V11"/>
                    <path d="M14 3c-1.5 2-1.5 4-1 6"/>
                    <path d="M10 3c1.5 2 1.5 4 1 6"/>
                    <path d="M6 5c2 .5 3.5 2 4 4"/>
                    <path d="M18 5c-2 .5-3.5 2-4 4"/>
                    <path d="M3 7c2.5 0 4.5 1.5 5.5 3"/>
                    <path d="M21 7c-2.5 0-4.5 1.5-5.5 3"/>
                </svg>
            </div>

            <h1 class="app-name">Who's <span>OOO</span></h1>

            <p class="tagline">
                {{ 'welcome.tagline'|trans }}
            </p>

            <div class="cta-group">
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('app_dashboard') }}" class="btn-welcome btn-welcome-primary">
                        <svg viewBox="0 0 24 24">
                            <rect x="3" y="3" width="7" height="7"/>
                            <rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/>
                            <rect x="14" y="14" width="7" height="7"/>
                        </svg>
                        {{ 'welcome.cta_dashboard'|trans }}
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn-welcome btn-welcome-primary">
                        <svg viewBox="0 0 24 24">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                            <polyline points="10 17 15 12 10 7"/>
                            <line x1="15" y1="12" x2="3" y2="12"/>
                        </svg>
                        {{ 'welcome.cta_signin'|trans }}
                    </a>
                {% endif %}

                <a href="https://github.com/igornast/who-is-out-of-office" class="btn-welcome btn-welcome-ghost" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    {{ 'welcome.cta_github'|trans }}
                </a>
            </div>

            <div class="features">
                <span class="feature-pill">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {{ 'welcome.feature_calendar'|trans }}
                </span>
                <span class="feature-pill">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    {{ 'welcome.feature_approvals'|trans }}
                </span>
                <span class="feature-pill">
                    <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                    {{ 'welcome.feature_integrations'|trans }}
                </span>
                <span class="feature-pill">
                    <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    {{ 'welcome.feature_dark_mode'|trans }}
                </span>
                <span class="feature-pill">
                    <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                    {{ 'welcome.feature_mobile'|trans }}
                </span>
                <span class="feature-pill">
                    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    {{ 'welcome.feature_selfhosted'|trans }}
                </span>
            </div>

        </div>
    </section>

    <footer class="welcome-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <a href="#" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    {{ 'welcome.footer_website'|trans }}
                </a>
                <div class="footer-divider"></div>
                <a href="https://github.com/igornast/who-is-out-of-office" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    {{ 'welcome.footer_github'|trans }}
                </a>
                <div class="footer-divider"></div>
                <a href="#" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    {{ 'welcome.footer_docs'|trans }}
                </a>
            </div>
            <p class="footer-version">{{ 'welcome.footer_version'|trans }}</p>
        </div>
    </footer>

</div>

</body>
</html>
