{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}{{ 'crud.user_profile.edit.page_title'|trans(domain='admin') }}{% endblock %}

{% block content_header %}
    <div class="content-header-title">
        <h1 class="title" style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text-primary);">
            {{ 'crud.user_profile.edit.title'|trans(domain='admin') }}
        </h1>
    </div>
{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'crud.user_profile.section.profile_info'|trans(domain='admin') }}</h3>
                </div>
                <div class="settings-card-body">
                    <div class="profile-avatar-upload" id="profile-image-container">
                        <div class="profile-avatar-zone" id="profile-avatar-zone">
                            {% if app.user.profileImageUrl %}
                                {% set img = app.user.profileImageUrl %}
                                {% if img starts with 'http://' or img starts with 'https://' %}
                                    {% set src = img %}
                                {% else %}
                                    {% set src = asset(profile_images_base_path ~ '/' ~ img) %}
                                {% endif %}
                                <img src="{{ src }}"
                                     alt="{{ 'crud.user_profile.field.profile_image'|trans(domain='admin') }}"
                                     id="profile-image-preview"
                                     class="profile-avatar-img">
                                <div class="profile-avatar-placeholder" id="profile-image-placeholder" style="display: none;">
                                    <i data-lucide="user"></i>
                                </div>
                            {% else %}
                                <div class="profile-avatar-placeholder" id="profile-image-placeholder">
                                    <i data-lucide="user"></i>
                                </div>
                                <img src="" alt="" id="profile-image-preview" class="profile-avatar-img" style="display: none;">
                            {% endif %}
                            <div class="profile-avatar-overlay" id="profile-avatar-overlay">
                                <i data-lucide="camera"></i>
                            </div>
                        </div>
                        <div class="profile-avatar-actions">
                            <button type="button" class="profile-avatar-change-btn" id="profile-image-change-btn">
                                <i data-lucide="upload"></i>
                                {{ 'crud.user_profile.field.profile_image_change'|trans(domain='admin') }}
                            </button>
                            <button type="button" class="profile-avatar-remove-btn" id="profile-image-remove-btn"{% if not app.user.profileImageUrl %} style="display: none;"{% endif %}>
                                <i data-lucide="trash-2"></i>
                                {{ 'crud.user_profile.field.profile_image_remove'|trans(domain='admin') }}
                            </button>
                        </div>
                        <div class="profile-avatar-hint">
                            {{ 'crud.user_profile.field.profile_image_help'|trans(domain='admin') }}
                        </div>
                        {{ form_widget(form.profileImageFile, {'attr': {'class': 'profile-avatar-file-input', 'accept': 'image/jpeg,image/png,image/webp'}}) }}
                        {{ form_widget(form.removeProfileImage) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="field-text form-group mb-3">
                                <div class="form-widget">
                                    {{ form_row(form.firstName, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="field-text form-group mb-3">
                                <div class="form-widget">
                                    {{ form_row(form.lastName, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="field-choice form-group mb-3">
                        <div class="form-widget">
                            {{ form_row(form.holidayCalendar, {'attr': {'class': 'form-select'}}) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">{{ 'crud.user_profile.field.working_days'|trans(domain='admin') }}</label>
                        <div class="d-flex flex-wrap gap-3">
                            {% for checkbox in form.workingDays %}
                                <div class="checkbox-large">
                                    {{ form_widget(checkbox) }}
                                    {{ form_label(checkbox) }}
                                </div>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.workingDays) }}
                    </div>
                </div>
            </div>

            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'crud.user_profile.section.employee_of_record'|trans(domain='admin') }}</h3>
                </div>
                <div class="settings-card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="field-choice form-group mb-3">
                                <div class="form-widget">
                                    {{ form_label(form.birthDate) }}
                                    {{ form_widget(form.birthDate, {'attr': {'class': 'form-control'}}) }}
                                </div>
                                <div class="form-text">{{ form_help(form.birthDate) }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="field-choice form-group mb-3">
                                <div class="form-widget">
                                    {{ form_label(form.contractStartedAt) }}
                                    {{ form_widget(form.contractStartedAt, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="field-choice form-group mb-3">
                                <div class="form-widget">
                                    {{ form_label(form.absenceBalanceResetDay) }}
                                    {{ form_widget(form.absenceBalanceResetDay, {'attr': {'class': 'form-control'}}) }}
                                </div>
                                <div class="form-text">{{ form_help(form.absenceBalanceResetDay) }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="field-choice form-group mb-0">
                        <div class="checkbox-large">
                            {{ form_widget(form.hasCelebrateWorkAnniversary) }}
                            {{ form_label(form.hasCelebrateWorkAnniversary) }}
                        </div>
                        <div class="form-text">{{ form_help(form.hasCelebrateWorkAnniversary) }}</div>
                    </div>
                </div>
            </div>

            <div class="settings-card">
                <div class="settings-card-header">
                    <h3 class="settings-card-title">{{ 'crud.user_profile.connected_services.title'|trans(domain='admin') }}</h3>
                </div>
                <div class="settings-card-body">
                    <div class="connected-service-row" id="slack">
                        <div class="connected-service-icon">
                            <i data-lucide="message-square"></i>
                        </div>
                        <div class="connected-service-info">
                            <div class="connected-service-name">{{ 'crud.user_profile.connected_services.slack.title'|trans(domain='admin') }}</div>
                            <div class="connected-service-desc">{{ 'crud.user_profile.connected_services.slack.description'|trans(domain='admin') }}</div>
                        </div>
                        <div class="connected-service-status" id="slack-status">
                            {% if slack_connected %}
                                <span class="connected-service-badge connected-service-badge-success">
                                    <i data-lucide="check-circle-2"></i>
                                    {{ 'crud.user_profile.connected_services.slack.connected'|trans(domain='admin') }}
                                </span>
                                <span class="connected-service-meta">{{ 'crud.user_profile.connected_services.slack.member_id'|trans({'%id%': slack_member_id}, domain='admin') }}</span>
                            {% else %}
                                <span class="connected-service-badge connected-service-badge-muted">
                                    {{ 'crud.user_profile.connected_services.slack.not_connected'|trans(domain='admin') }}
                                </span>
                            {% endif %}
                        </div>
                        <div class="connected-service-action">
                            <button class="btn btn-outline btn-sm" id="slack-configure-btn" type="button"
                                    data-update-url="{{ path('app_api_slack_update') }}"
                                    data-disconnect-url="{{ path('app_api_slack_disconnect') }}"
                                    data-csrf-update="{{ csrf_token('slack_update') }}"
                                    data-csrf-disconnect="{{ csrf_token('slack_disconnect') }}"
                                    data-member-id="{{ slack_member_id ?? '' }}">
                                <i data-lucide="settings"></i>
                                {{ 'crud.user_profile.connected_services.slack.configure'|trans(domain='admin') }}
                            </button>
                        </div>
                    </div>

                    <div class="connected-service-row">
                        <div class="connected-service-icon">
                            <i data-lucide="calendar"></i>
                        </div>
                        <div class="connected-service-info">
                            <div class="connected-service-name">{{ 'crud.user_profile.connected_services.calendar.title'|trans(domain='admin') }}</div>
                            <div class="connected-service-desc">{{ 'crud.user_profile.connected_services.calendar.description'|trans(domain='admin') }}</div>
                        </div>
                        <div class="connected-service-action">
                            <div class="connected-service-url-group">
                                <input type="text" class="connected-service-url-input" id="profile-cal-url" readonly value="{{ calendar_subscription_url }}">
                                <div class="connected-service-url-actions">
                                    <button class="btn btn-outline btn-sm" id="profile-copy-cal-url" type="button">
                                        <i data-lucide="copy"></i>
                                        {{ 'crud.user_profile.connected_services.calendar.copy_url'|trans(domain='admin') }}
                                    </button>
                                    <button class="btn btn-outline btn-sm" id="profile-regenerate-cal-url" type="button"
                                            data-regenerate-url="{{ path('app_api_calendar_regenerate') }}"
                                            data-csrf-token="{{ csrf_token('calendar_regenerate') }}">
                                        <i data-lucide="refresh-cw"></i>
                                        {{ 'crud.user_profile.connected_services.calendar.regenerate'|trans(domain='admin') }}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="settings-card-footer">
                    {{ form_errors(form) }}
                    <button class="btn btn-primary">{{ 'crud.user_profile.action.save_changes'|trans(domain='admin') }}</button>
                </div>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    <div class="modal fade" id="slackConfigModal" tabindex="-1" aria-labelledby="slackConfigModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="slackConfigModalLabel">{{ 'crud.user_profile.connected_services.slack.modal_title'|trans(domain: 'admin') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="slack-member-id-input" class="form-label">{{ 'crud.user_profile.connected_services.slack.modal_field_label'|trans(domain: 'admin') }}</label>
                        <input type="text" class="form-control" id="slack-member-id-input" placeholder="U0123456789">
                        <div class="form-text">{{ 'crud.user_profile.connected_services.slack.modal_field_help'|trans(domain: 'admin') }}</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger me-auto" id="slackDisconnectBtn" style="display: none;">{{ 'crud.user_profile.connected_services.slack.modal_disconnect'|trans(domain: 'admin') }}</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'crud.user_profile.connected_services.slack.modal_cancel'|trans(domain: 'admin') }}</button>
                    <button type="button" class="btn btn-primary" id="slackSaveBtn">{{ 'crud.user_profile.connected_services.slack.modal_save'|trans(domain: 'admin') }}</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="regenerateConfirmModal" tabindex="-1" aria-labelledby="regenerateConfirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="regenerateConfirmModalLabel">{{ 'crud.user_profile.connected_services.calendar.regenerate_confirm_title'|trans(domain: 'admin') }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    {{ 'crud.user_profile.connected_services.calendar.regenerate_confirm_body'|trans(domain: 'admin') }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'crud.user_profile.connected_services.calendar.regenerate_cancel'|trans(domain: 'admin') }}</button>
                    <button type="button" class="btn btn-danger" id="regenerateConfirmBtn">{{ 'crud.user_profile.connected_services.calendar.regenerate_confirm_action'|trans(domain: 'admin') }}</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block body_javascript %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var imageInput = document.getElementById('{{ form.profileImageFile.vars.id }}');
            var imagePreview = document.getElementById('profile-image-preview');
            var imagePlaceholder = document.getElementById('profile-image-placeholder');
            var removeBtn = document.getElementById('profile-image-remove-btn');
            var removeFlag = document.getElementById('{{ form.removeProfileImage.vars.id }}');
            var changeBtn = document.getElementById('profile-image-change-btn');
            var avatarZone = document.getElementById('profile-avatar-zone');

            if (changeBtn && imageInput) {
                changeBtn.addEventListener('click', function() { imageInput.click(); });
            }
            if (avatarZone && imageInput) {
                avatarZone.addEventListener('click', function() { imageInput.click(); });
            }

            if (imageInput) {
                imageInput.addEventListener('change', function() {
                    var file = this.files[0];
                    if (!file) return;

                    var reader = new FileReader();
                    reader.onload = function(e) {
                        imagePreview.src = e.target.result;
                        imagePreview.style.display = '';
                        if (imagePlaceholder) imagePlaceholder.style.display = 'none';
                        if (removeFlag) removeFlag.value = '';
                        if (removeBtn) removeBtn.style.display = '';
                    };
                    reader.readAsDataURL(file);
                });
            }

            if (removeBtn && removeFlag) {
                removeBtn.addEventListener('click', function() {
                    removeFlag.value = '1';
                    imagePreview.style.display = 'none';
                    removeBtn.style.display = 'none';
                    if (imageInput) imageInput.value = '';
                    if (imagePlaceholder) {
                        imagePlaceholder.style.display = '';
                    }
                });
            }

            var copyBtn = document.getElementById('profile-copy-cal-url');
            if (copyBtn) {
                copyBtn.addEventListener('click', function() {
                    var urlInput = document.getElementById('profile-cal-url');
                    navigator.clipboard.writeText(urlInput.value);
                    var originalHtml = copyBtn.innerHTML;
                    copyBtn.innerHTML = '<i data-lucide="check"></i> {{ "crud.user_profile.connected_services.calendar.copied"|trans(domain: "admin") }}';
                    if (typeof lucide !== 'undefined') { lucide.createIcons(); }
                    setTimeout(function() {
                        copyBtn.innerHTML = originalHtml;
                        if (typeof lucide !== 'undefined') { lucide.createIcons(); }
                    }, 2000);
                });
            }

            var slackConfigureBtn = document.getElementById('slack-configure-btn');
            var slackModal = document.getElementById('slackConfigModal');
            var slackMemberIdInput = document.getElementById('slack-member-id-input');
            var slackSaveBtn = document.getElementById('slackSaveBtn');
            var slackDisconnectBtn = document.getElementById('slackDisconnectBtn');
            var slackStatus = document.getElementById('slack-status');

            if (slackConfigureBtn && slackModal) {
                var bsSlackModal = new bootstrap.Modal(slackModal);

                slackConfigureBtn.addEventListener('click', function() {
                    var memberId = slackConfigureBtn.dataset.memberId;
                    slackMemberIdInput.value = memberId;
                    slackDisconnectBtn.style.display = memberId ? '' : 'none';
                    bsSlackModal.show();
                });

                slackSaveBtn.addEventListener('click', function() {
                    var memberId = slackMemberIdInput.value.trim();
                    if (!memberId) return;

                    var url = slackConfigureBtn.dataset.updateUrl;
                    var csrfToken = slackConfigureBtn.dataset.csrfUpdate;

                    slackSaveBtn.disabled = true;
                    slackSaveBtn.textContent = '{{ "crud.user_profile.connected_services.slack.modal_saving"|trans(domain: "admin") }}';

                    var formData = new FormData();
                    formData.append('_token', csrfToken);
                    formData.append('slack_member_id', memberId);

                    fetch(url, { method: 'POST', body: formData })
                        .then(function(response) { return response.json(); })
                        .then(function(data) {
                            if (data.success) {
                                slackConfigureBtn.dataset.memberId = data.memberId;
                                slackStatus.innerHTML = '<span class="connected-service-badge connected-service-badge-success"><i data-lucide="check-circle-2"></i> {{ "crud.user_profile.connected_services.slack.connected"|trans(domain: "admin") }}</span>' +
                                    '<span class="connected-service-meta">{{ "crud.user_profile.connected_services.slack.member_id"|trans(domain: "admin") }}'.replace('%id%', data.memberId) + '</span>';
                                if (typeof lucide !== 'undefined') { lucide.createIcons(); }
                                bsSlackModal.hide();
                            }
                            slackSaveBtn.disabled = false;
                            slackSaveBtn.textContent = '{{ "crud.user_profile.connected_services.slack.modal_save"|trans(domain: "admin") }}';
                        })
                        .catch(function() {
                            slackSaveBtn.disabled = false;
                            slackSaveBtn.textContent = '{{ "crud.user_profile.connected_services.slack.modal_save"|trans(domain: "admin") }}';
                        });
                });

                slackDisconnectBtn.addEventListener('click', function() {
                    var url = slackConfigureBtn.dataset.disconnectUrl;
                    var csrfToken = slackConfigureBtn.dataset.csrfDisconnect;

                    slackDisconnectBtn.disabled = true;

                    var formData = new FormData();
                    formData.append('_token', csrfToken);

                    fetch(url, { method: 'POST', body: formData })
                        .then(function(response) { return response.json(); })
                        .then(function(data) {
                            if (data.success) {
                                slackConfigureBtn.dataset.memberId = '';
                                slackStatus.innerHTML = '<span class="connected-service-badge connected-service-badge-muted">{{ "crud.user_profile.connected_services.slack.not_connected"|trans(domain: "admin") }}</span>';
                                bsSlackModal.hide();
                            }
                            slackDisconnectBtn.disabled = false;
                        })
                        .catch(function() {
                            slackDisconnectBtn.disabled = false;
                        });
                });
            }

            var regenerateBtn = document.getElementById('profile-regenerate-cal-url');
            var regenerateModal = document.getElementById('regenerateConfirmModal');
            var regenerateConfirmBtn = document.getElementById('regenerateConfirmBtn');

            if (regenerateBtn && regenerateModal) {
                var bsModal = new bootstrap.Modal(regenerateModal);

                regenerateBtn.addEventListener('click', function() {
                    bsModal.show();
                });

                regenerateConfirmBtn.addEventListener('click', function() {
                    bsModal.hide();

                    var url = regenerateBtn.dataset.regenerateUrl;
                    var csrfToken = regenerateBtn.dataset.csrfToken;
                    var originalHtml = regenerateBtn.innerHTML;

                    regenerateBtn.disabled = true;
                    regenerateBtn.innerHTML = '<i data-lucide="loader"></i> {{ "crud.user_profile.connected_services.calendar.regenerating"|trans(domain: "admin") }}';
                    if (typeof lucide !== 'undefined') { lucide.createIcons(); }

                    var formData = new FormData();
                    formData.append('_token', csrfToken);

                    fetch(url, { method: 'POST', body: formData })
                        .then(function(response) { return response.json(); })
                        .then(function(data) {
                            if (data.success) {
                                var urlInput = document.getElementById('profile-cal-url');
                                urlInput.value = data.url;
                                regenerateBtn.innerHTML = '<i data-lucide="check"></i> {{ "crud.user_profile.connected_services.calendar.regenerated"|trans(domain: "admin") }}';
                                if (typeof lucide !== 'undefined') { lucide.createIcons(); }
                                setTimeout(function() {
                                    regenerateBtn.innerHTML = originalHtml;
                                    regenerateBtn.disabled = false;
                                    if (typeof lucide !== 'undefined') { lucide.createIcons(); }
                                }, 2000);
                            }
                        })
                        .catch(function() {
                            regenerateBtn.innerHTML = originalHtml;
                            regenerateBtn.disabled = false;
                            if (typeof lucide !== 'undefined') { lucide.createIcons(); }
                        });
                });
            }
        });
    </script>
{% endblock %}
