<div {{ attributes }} class="card" style="margin-bottom: 20px;">
    <div class="week-strip">
        <div class="week-header">
            <span class="week-title">
                {%- if this.isCurrentWeek -%}
                    {{ 'dashboard.week_strip.title'|trans(domain: 'admin') }} — {{ this.formattedDateRange }}
                {%- else -%}
                    {{ this.formattedDateRange }}
                {%- endif -%}
            </span>
            <div class="week-nav">
                <button data-action="live#action" data-live-action-param="prev" title="{{ 'dashboard.week_strip.prev'|trans(domain: 'admin') }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button data-action="live#action" data-live-action-param="next" title="{{ 'dashboard.week_strip.next'|trans(domain: 'admin') }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
        <div class="week-days">
            {% for day in this.days %}
                <div class="week-day{{ day.isToday ? ' today' : '' }}">
                    <div class="week-day-name">{{ day.dayName }}</div>
                    <div class="week-day-num">{{ day.dayNumber }}</div>
                    {% if day.absenceCount > 0 %}
                        <div class="week-day-count has-leaves">{{ day.absenceCount }} {{ 'dashboard.week_strip.out'|trans(domain: 'admin') }}</div>
                        <div class="week-day-avatars">
                            {% set max_avatars = 3 %}
                            {% for avatar in day.avatars|slice(0, max_avatars) %}
                                <div class="mini-avatar" style="background: {{ avatar.leaveTypeBackgroundColor }}" title="{{ avatar.firstName }} {{ avatar.lastName }}">
                                    {% if avatar.profileImageUrl %}
                                        {% if avatar.profileImageUrl starts with 'http://' or avatar.profileImageUrl starts with 'https://' %}
                                            <img src="{{ avatar.profileImageUrl }}" alt="">
                                        {% else %}
                                            <img src="{{ asset(profile_images_base_path ~ '/' ~ avatar.profileImageUrl) }}" alt="">
                                        {% endif %}
                                    {% else %}
                                        {{ avatar.firstName|first }}{{ avatar.lastName|first }}
                                    {% endif %}
                                </div>
                            {% endfor %}
                            {% if day.absenceCount > max_avatars %}
                                <div class="mini-avatar mini-avatar--overflow">
                                    +{{ day.absenceCount - max_avatars }}
                                </div>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="week-day-count">&nbsp;</div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
</div>
