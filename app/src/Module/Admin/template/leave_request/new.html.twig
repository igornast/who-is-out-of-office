{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}{{ 'leave_request.new.page_title'|trans(domain: 'admin') }}{% endblock %}

{% block head_stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('vendor/flatpickr/dist/flatpickr.min.css') }}">
{% endblock %}

{% block content_header %}
    <div class="content-header-title">
        <h1 class="title" style="font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--text-primary);">
            {{ 'leave_request.new.heading'|trans(domain: 'admin') }}
        </h1>
    </div>
{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="card" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-md);">
                <div class="card-body lr-form-card-body">
                    {{ component('LeaveRequestForm') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
