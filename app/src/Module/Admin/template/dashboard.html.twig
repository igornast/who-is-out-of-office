{% extends '@AppAdmin/layout.html.twig' %}

{% block page_title %}Who's OOO App{% endblock %}

{% block content_header %}
    {% include '@AppAdmin/dashboard/_welcome_banner.html.twig' %}
{% endblock %}

{% block main %}
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon sand">
                    <i data-lucide="clock"></i>
                </div>
            </div>
            <div class="stat-value">{{ pending_requests|length }}</div>
            <div class="stat-label">{{ 'dashboard.stats.pending_requests'|trans(domain: 'admin') }}</div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon teal">
                    <i data-lucide="user-check"></i>
                </div>
            </div>
            <div class="stat-value">{{ upcoming_absences_in_team|length }}</div>
            <div class="stat-label">{{ 'dashboard.stats.upcoming_absences'|trans(domain: 'admin') }}</div>
        </div>
        {# TODO Backend: Wire a dedicated `absences_this_week` count variable (see backend-tasks.md §1.4 countAbsencesThisWeek).
           Current approximation filters upcoming_absences_in_team (max 4 approved, next 30d) — inaccurate for a real count. #}
        {% set week_end = "sunday this week"|date("Y-m-d") %}
        {% set absences_this_week = upcoming_absences_in_team|filter(lr => lr.startDate|date("Y-m-d") <= week_end) %}
        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon lavender">
                    <i data-lucide="calendar-range"></i>
                </div>
            </div>
            <div class="stat-value">{{ absences_this_week|length }}</div>
            <div class="stat-label">{{ 'dashboard.stats.absences_this_week'|trans(domain: 'admin') }}</div>
        </div>
        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon sand">
                    <i data-lucide="palmtree"></i>
                </div>
            </div>
            <div class="stat-value">{{ user.currentLeaveBalance }}<span
                        style="font-size:16px;font-weight:400;color:var(--text-muted)"> {{ 'dashboard.stats.days'|trans(domain: 'admin') }}</span>
            </div>
            <div class="stat-label">{{ 'dashboard.stats.vacation_balance'|trans(domain: 'admin') }}</div>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="dashboard-left-column">
            {% include '@AppAdmin/dashboard/_upcoming_absences.html.twig' %}
            <div style="margin-top: 20px;">

                {% include '@AppAdmin/dashboard/_recent_requests.html.twig' %}
            </div>

            <div style="margin-top: 20px;">
                {% include '@AppAdmin/dashboard/_my_team.html.twig' %}
            </div>
        </div>

        <div class="dashboard-right-column">
            {% include '@AppAdmin/dashboard/_quick_links.html.twig' %}

            <div class="card">
                <div class="card-header">
                    <span class="card-title">{{ 'dashboard.title.birthdays'|trans(domain: 'admin') }}</span>
                </div>
                <div class="card-body" style="padding: 16px 20px;">
                    {% if users_with_birthdays is not empty %}
                        {% import "@AppAdmin/dashboard/component/_user_avatar.html.twig" as avatar %}
                        <div class="d-flex flex-wrap gap-4">
                            {% for userDto in users_with_birthdays %}
                                <div class="text-center">
                                    {{ avatar.userDtoAvatar(userDto) }}
                                    <div class="text-center mt-2" style="font-size: 12px; color: var(--text-muted);">
                                        {{ userDto.birthDate|date("m.d") }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div style="padding: 8px 0; text-align: center; color: var(--text-muted); font-size: 13px;">
                            {{ 'dashboard.birthdays.no_upcoming'|trans(domain: 'admin') }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">{{ 'dashboard.work_anniversaries.title'|trans(domain: 'admin') }}</span>
                </div>
                <div class="card-body" style="padding: 16px 20px;">
                    {% if users_with_work_anniversaries is not empty %}
                        {% import "@AppAdmin/dashboard/component/_user_avatar.html.twig" as avatar %}
                        <div class="d-flex flex-wrap gap-4">
                            {% for userDto in users_with_work_anniversaries %}
                                <div class="text-center">
                                    {{ avatar.userDtoAvatar(userDto) }}
                                    <div class="text-center mt-2" style="font-size: 12px; color: var(--text-muted);">
                                        {{ userDto.contractStartedAt|date("m.d") }}
                                        {% if userDto.contractStartedAt %}
                                            {% set years = "now"|date("Y") - userDto.contractStartedAt|date("Y") %}
                                            {% if years > 0 %}
                                                <small class="d-block" style="color: var(--text-tertiary);">{{ years }}
                                                    y</small>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div style="padding: 8px 0; text-align: center; color: var(--text-muted); font-size: 13px;">
                            {{ 'dashboard.work_anniversaries.no_upcoming'|trans(domain: 'admin') }}
                        </div>
                    {% endif %}
                </div>
            </div>

            {% if slack_integration is not null %}
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">{{ 'dashboard.title.slack'|trans(domain: 'admin') }}</span>
                    </div>
                    <div class="card-body" style="padding: 16px 20px;">
                        <div style="font-size: 13px; color: var(--text-secondary);">
                            Slack Member ID: {{ user.slackIntegration.slackMemberId }}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock main %}
