{
    "name": "igornast/who-is-out-of-office",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "igor.nastarowicz"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^3.10.2",
        "doctrine/doctrine-bundle": "^2.16.2",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.5.2",
        "easycorp/easyadmin-bundle": "^4.25.1",
        "eluceo/ical": "^2.15",
        "guzzlehttp/psr7": "^2.8.0",
        "illuminate/collections": "^12.32.5",
        "phpdocumentor/reflection-docblock": "^5.6.3",
        "phpstan/phpdoc-parser": "^2.3",
        "ramsey/uuid": "^4.9.1",
        "ramsey/uuid-doctrine": "^2.1",
        "sentry/sentry-symfony": "^5.6",
        "symfony/asset": "7.2.*",
        "symfony/asset-mapper": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/expression-language": "7.2.*",
        "symfony/flex": "^2.8.2",
        "symfony/framework-bundle": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/notifier": "7.2.*",
        "symfony/password-hasher": "7.2.*",
        "symfony/property-access": "7.2.*",
        "symfony/property-info": "7.2.*",
        "symfony/runtime": "7.2.*",
        "symfony/serializer": "7.2.*",
        "symfony/slack-notifier": "7.2.*",
        "symfony/stimulus-bundle": ">=2.30",
        "symfony/twig-bundle": "7.2.*",
        "symfony/ux-live-component": ">=2.30",
        "symfony/yaml": "7.2.*",
        "tattali/calendar-bundle": "^7.0.1",
        "twig/extra-bundle": "^2.12|^3.21",
        "twig/twig": "^2.12|^3.21.1"
    },
    "require-dev": {
        "dbrekelmans/bdi": "^1.4",
        "doctrine/doctrine-fixtures-bundle": "^4.1",
        "friendsofphp/php-cs-fixer": "^3.88.2",
        "mockery/mockery": "^1.6.12",
        "nelmio/alice": "^3.14.2",
        "pestphp/pest": "^3.8.2",
        "phpstan/phpstan": "^2.1.30",
        "phpunit/phpunit": "^11.5.15",
        "symfony/browser-kit": "7.3.*",
        "symfony/css-selector": "7.3.*",
        "symfony/panther": "^2.3",
        "symfony/stopwatch": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test:phpunit:u": "./vendor/bin/pest --testsuite Unit --coverage --compact",
        "test:phpunit:f": "./vendor/bin/pest --testsuite Functional --display-warnings --display-errors",
        "test:arch": "./vendor/bin/pest tests/Architecture --compact",
        "test:cs": "./vendor/bin/php-cs-fixer fix --dry-run --diff -v",
        "test:cs:fix": "./vendor/bin/php-cs-fixer fix --diff -v",
        "test:stan": "./vendor/bin/phpstan analyse -c phpstan.neon",
        "test": [
            "@test:cs",
            "@test:stan",
            "@test:arch",
            "@test:phpunit:u",
            "@test:phpunit:f"
        ],
        "test-ci": [
            "@test:cs",
            "@test:stan",
            "@test:arch",
            "./vendor/bin/pest --testsuite Unit --coverage --coverage-clover clover.xml",
            "@reset-test-db",
            "@test:phpunit:f"
        ],
        "reset-test-db": [
            "php bin/console doctrine:database:drop --if-exists --force --env=test",
            "php bin/console doctrine:database:create --env=test",
            "php bin/console doctrine:schema:update --force --env=test",
            "php bin/console doctrine:fixtures:load --no-interaction --env=test"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.3.*"
        }
    }
}
