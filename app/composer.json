{
    "name": "igornast/who-is-out-of-office",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "igor.nastarowicz"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^3.9.4",
        "doctrine/doctrine-bundle": "^2.14.0",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.3.3",
        "easycorp/easyadmin-bundle": "^4.24.7",
        "eluceo/ical": "^2.14",
        "illuminate/collections": "^12.17.0",
        "ramsey/uuid": "^4.8.1",
        "ramsey/uuid-doctrine": "^2.1",
        "symfony/console": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/expression-language": "7.2.*",
        "symfony/flex": "^2.7.1",
        "symfony/framework-bundle": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/notifier": "7.2.*",
        "symfony/password-hasher": "7.2.*",
        "symfony/runtime": "7.2.*",
        "symfony/slack-notifier": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/yaml": "7.2.*",
        "tattali/calendar-bundle": "^7.0"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.1",
        "friendsofphp/php-cs-fixer": "^3.75",
        "mockery/mockery": "^1.6",
        "nelmio/alice": "^3.14.2",
        "pestphp/pest": "^3.8",
        "phpstan/phpstan": "^2.1.17",
        "phpunit/phpunit": "^11.5.15",
        "symfony/stopwatch": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test:phpunit:u": "./vendor/bin/pest --testsuite Unit --coverage --compact --min=90",
        "test:cs": "PHP_CS_FIXER_IGNORE_ENV=true ./vendor/bin/php-cs-fixer fix --dry-run --diff -v",
        "test:cs:fix": "PHP_CS_FIXER_IGNORE_ENV=true ./vendor/bin/php-cs-fixer fix --diff -v",
        "test:stan": "./vendor/bin/phpstan analyse -c phpstan.neon",
        "test": [
            "@test:cs",
            "@test:stan",
            "@test:phpunit:u"
        ],
        "test-ci": [
            "@test:cs",
            "@test:stan",
            "./vendor/bin/pest --testsuite Unit --coverage --coverage-clover clover.xml"
        ],
        "reset-test-db": [
            "php bin/console doctrine:database:drop --if-exists --force --env=test",
            "php bin/console doctrine:database:create --env=test",
            "php bin/console doctrine:schema:update --force --env=test",
            "php bin/console doctrine:fixtures:load --no-interaction --env=test"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    }
}
